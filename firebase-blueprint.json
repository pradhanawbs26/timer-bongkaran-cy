{
  "entities": {
    "SessionState": {
      "title": "SessionState",
      "description": "The dynamic live session state of the Container Yard",
      "type": "object",
      "properties": {
        "isSessionActive": {
          "type": "boolean"
        },
        "startTime": {
          "type": "string"
        },
        "trainsetId": {
          "type": "string"
        },
        "supervisorName": {
          "type": "string"
        },
        "containersUnloaded": {
          "type": "integer"
        },
        "breachedAlertSent": {
          "type": "boolean"
        },
        "finalBreachedAlertSent": {
          "type": "boolean"
        },
        "isPaused": {
          "type": "boolean"
        },
        "previouslyAccumulatedSeconds": {
          "type": "integer"
        },
        "resumeTime": {
          "type": "string"
        }
      }
    },
    "HistoryItem": {
      "title": "HistoryItem",
      "description": "Historic logged/completed unloading sessions",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "trainsetId": {
          "type": "string"
        },
        "startTime": {
          "type": "string"
        },
        "endTime": {
          "type": "string"
        },
        "actualDurationMinutes": {
          "type": "integer"
        },
        "targetMinutes": {
          "type": "integer"
        },
        "containersUnloaded": {
          "type": "integer"
        },
        "targetVolume": {
          "type": "integer"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "WhatsAppConfig": {
      "title": "WhatsAppConfig",
      "description": "Centralized WhatsApp API integration settings",
      "type": "object",
      "properties": {
        "webhookUrl": {
          "type": "string"
        },
        "token": {
          "type": "string"
        },
        "groupId": {
          "type": "string"
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": ["webhookUrl", "token", "groupId"]
    }
  },
  "firestore": {
    "sessions/current": {
      "schema": "SessionState",
      "description": "Stores the currently running unloading session state"
    },
    "settings/whatsapp": {
      "schema": "WhatsAppConfig",
      "description": "Central WhatsApp API gateway credentials and endpoint"
    },
    "history/{itemId}": {
      "schema": "HistoryItem",
      "description": "Collection of previous unloading session history items"
    }
  }
}
