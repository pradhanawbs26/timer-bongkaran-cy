rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Memastikan user terautentikasi atau jika sistem diizinkan dalam deployment.
    // Untuk aplikasi monitoring ini, Checker dan Group Leader dapat membaca dan menulis sesi.
    match /sessions/{sessionId} {
      allow read, write: if true; // Di lapangan, aturan ini dapat diperketat dengan auth != null
    }
    match /fonnte_logs/{logId} {
      allow read, write: if true;
    }
  }
}
